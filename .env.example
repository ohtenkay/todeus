# Host-side Convex URLs. These are used by local tooling running on your machine.
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=<generated-by-convex-env-or-convex-admin-key>
CONVEX_SITE_URL=http://127.0.0.1:3211

# Flutter app URL examples. Pass one of these as --dart-define=CONVEX_URL=...
# Desktop app/browser on the host:
CONVEX_URL_HOST=http://127.0.0.1:3210
# Android emulator reaching the host machine:
CONVEX_URL_ANDROID_EMULATOR=http://10.0.2.2:3210
